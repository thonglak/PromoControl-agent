# ─────────────────────────────────────────────────────────────
# Production environment file
#  คัดลอกเป็น deploy/.env.production แล้วแก้ค่าให้ตรงกับ server จริง
#  ห้าม commit ไฟล์ .env.production (ถูก gitignored แล้ว)
#
#  ใช้คู่กับ docker-compose.prod.yml ผ่าน volume mount:
#    - mount → /var/www/backend/.env (CodeIgniter 4 อ่านจากไฟล์นี้)
#    - docker compose ใช้ ENV เดียวกัน (MYSQL_*, HTTP_PORT)
# ─────────────────────────────────────────────────────────────

# ── ค่าที่ docker-compose.prod.yml อ่าน (สร้าง MySQL container) ──
MYSQL_ROOT_PASSWORD=change_me_root_pass
MYSQL_DATABASE=promo_db
MYSQL_USER=promo_user
MYSQL_PASSWORD=change_me_user_pass

# Port ที่ host เปิดให้ traffic ภายนอกเข้า (production ใช้ 8580 — แนะนำมี reverse proxy SSL ด้านหน้า)
HTTP_PORT=8580

# phpMyAdmin (production) — แนะนำห้าม expose สู่ public, ใช้ผ่าน VPN/SSH tunnel
PMA_PORT=8581

# ── CodeIgniter 4 .env (ถูก mount เข้า container) ─────────────
CI_ENVIRONMENT=production

app.baseURL='https://your-domain.com'
app.defaultLocale='th'
app.indexPage=''

# Database — ต้องตรงกับ MYSQL_* ด้านบน, hostname ใช้ service name ใน compose
database.default.hostname=promo_mysql_prod
database.default.database=promo_db
database.default.username=promo_user
database.default.password=change_me_user_pass
database.default.DBDriver=MySQLi
database.default.port=3306
database.default.charset=utf8mb4
database.default.DBCollat=utf8mb4_unicode_ci

# JWT — ต้องสุ่มใหม่บน production (เช่น: openssl rand -hex 32)
JWT_SECRET=change_me_random_64_hex_chars

# Narai SSO OAuth2 — ขอจาก Narai Connect admin
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_REDIRECT_URI=https://your-domain.com/api/auth/sso/callback
# scope ที่ขอจาก Narai Connect — เว้นว่างจะใช้ default 'email read.projects'
# ค่ามี space ต้องครอบด้วย double quotes (CI4 DotEnv parser)
OAUTH2_SCOPE="email read.projects"
APP_FRONTEND_URL=https://your-domain.com

# Initial admin (ใช้ตอน seed/migrate ครั้งแรก)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=change_me_strong_password

# Logging — production ลด level เหลือ critical/error เท่านั้น
logger.threshold=4

# ── External databases (multi-DB) ─────────────────────────────
# เชื่อม DB ภายนอกผ่าน docker external networks
# ก่อนใช้ ต้อง:
#   1) attach network ที่ docker-compose.prod.yml ของ promo_php_prod
#      (เพิ่ม networks: back_db_network, front_db_network เป็น external: true)
#   2) สร้าง connection group ใน app/Config/Database.php (เช่น 'back', 'front')
#   3) เรียกใช้ผ่าน \Config\Database::connect('back')
#
# port ใช้ 3306 (ภายใน container) — ไม่ใช่ port ที่ map สู่ host
#
# back_db
#database.back.hostname=back_db
#database.back.database=
#database.back.username=
#database.back.password=
#database.back.DBDriver=MySQLi
#database.back.port=3306
#database.back.charset=utf8mb4
#database.back.DBCollat=utf8mb4_unicode_ci
#
# front_db
#database.front.hostname=front_db
#database.front.database=
#database.front.username=
#database.front.password=
#database.front.DBDriver=MySQLi
#database.front.port=3306
#database.front.charset=utf8mb4
#database.front.DBCollat=utf8mb4_unicode_ci
#
# db (mariadb_network — hostname: db)
#database.db.hostname=db
#database.db.database=
#database.db.username=
#database.db.password=
#database.db.DBDriver=MySQLi
#database.db.port=3306
#database.db.charset=utf8mb4
#database.db.DBCollat=utf8mb4_unicode_ci
