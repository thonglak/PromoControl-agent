# ─────────────────────────────────────────────────────────────
# Frontend serve-only image — ใช้ dist ที่ build มาแล้วจากภายนอก
#
# ใช้เป็น workaround สำหรับ host ที่ esbuild crash ตอน ng build ในคอนเทนเนอร์
# (seccomp/clone3 บน CentOS 7 + libseccomp เก่า)
#
# ขั้นตอน:
#   1) build dist ใน docker run ที่ปิด seccomp:
#        docker run --rm --security-opt seccomp=unconfined \
#          -v "$PWD/frontend":/app -w /app node:22-alpine \
#          sh -c "npm ci --no-audit --no-fund && npx ng build --configuration=production"
#   2) ประกอบ image นี้ (ไม่มี RUN ที่ต้องสร้าง thread → ไม่ติด seccomp):
#        docker build -f docker/frontend/Dockerfile.serve -t promo_nginx:prod .
#   3) ./deploy/deploy.sh --no-build
# ─────────────────────────────────────────────────────────────

FROM nginx:1.27-alpine

# ลบ default config
RUN rm /etc/nginx/conf.d/default.conf

# Copy production nginx config
COPY docker/nginx/default.prod.conf /etc/nginx/conf.d/default.conf

# Copy Angular bundle ที่ prebuilt มาแล้ว (Angular 21 outputPath = dist/app/browser)
COPY frontend/dist/app/browser /usr/share/nginx/html

EXPOSE 80
