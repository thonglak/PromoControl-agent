# ─────────────────────────────────────────────────────────────
# Production Frontend image — Angular 21 → static files served by Nginx
#  - Stage 1: build Angular bundle ด้วย ng build --configuration=production
#  - Stage 2: nginx alpine serve static + reverse proxy /api → PHP-FPM
# ─────────────────────────────────────────────────────────────

# ── Stage 1: Builder ─────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

# ติดตั้ง dependency ก่อน copy source ทั้งหมด เพื่อใช้ Docker cache
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm ci --no-audit --no-fund

# Copy source ทั้งหมด
COPY frontend/ ./

# Build production bundle
RUN npx ng build --configuration=production


# ── Stage 2: Nginx serve static + reverse proxy ─────────────
FROM nginx:1.27-alpine

# ลบ default config
RUN rm /etc/nginx/conf.d/default.conf

# Copy production nginx config
COPY docker/nginx/default.prod.conf /etc/nginx/conf.d/default.conf

# Copy built Angular ไปไว้ที่ web root
# Angular 21 default outputPath = dist/<project>/browser
COPY --from=builder /app/dist/app/browser /usr/share/nginx/html

EXPOSE 80
