# ─────────────────────────────────────────────────────────────
# Production PHP-FPM image — CodeIgniter 4 backend
#  - Stage 1 (builder): compile extensions + composer install --no-dev
#  - Stage 2 (final):   runtime libs + copy compiled extensions
#  - opcache validate_timestamps=0 (deploy → restart container)
# ─────────────────────────────────────────────────────────────

FROM php:8.2-fpm-alpine AS builder

# Build deps (รวม -dev headers สำหรับ compile PHP extensions)
RUN apk add --no-cache \
        git \
        unzip \
        icu-dev \
        libzip-dev \
        oniguruma-dev \
    && docker-php-ext-install -j$(nproc) \
        pdo_mysql \
        mysqli \
        mbstring \
        zip \
        bcmath \
        intl \
        opcache

COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

WORKDIR /var/www/backend

# ติดตั้ง dependency ก่อน copy source ทั้งหมด เพื่อใช้ Docker cache
COPY backend/composer.json backend/composer.lock* ./
RUN composer install \
        --no-dev \
        --no-interaction \
        --no-scripts \
        --prefer-dist \
        --optimize-autoloader \
    && rm -rf /root/.composer

# Copy source ทั้งหมด
COPY backend/ ./

# Generate optimized autoload หลัง copy เสร็จ
RUN composer dump-autoload --optimize --no-dev

# ─────────────────────────────────────────────────────────────
# Final image — runtime libs + extension binaries จาก builder
#  ไม่มี git/composer/dev tools เพื่อลด attack surface และ size
# ─────────────────────────────────────────────────────────────
FROM php:8.2-fpm-alpine

# ติดตั้งเฉพาะ runtime libraries (ไม่มี -dev)
RUN apk add --no-cache \
        icu-libs \
        libzip \
        oniguruma

# Copy compiled extension binaries (.so) + ไฟล์ config ที่โหลด extension
COPY --from=builder /usr/local/lib/php/extensions/ /usr/local/lib/php/extensions/
COPY --from=builder /usr/local/etc/php/conf.d/ /usr/local/etc/php/conf.d/

# Production opcache config
RUN { \
        echo 'opcache.enable=1'; \
        echo 'opcache.enable_cli=0'; \
        echo 'opcache.memory_consumption=128'; \
        echo 'opcache.interned_strings_buffer=16'; \
        echo 'opcache.max_accelerated_files=10000'; \
        echo 'opcache.validate_timestamps=0'; \
        echo 'opcache.revalidate_freq=0'; \
        echo 'opcache.fast_shutdown=1'; \
    } > /usr/local/etc/php/conf.d/opcache-prod.ini

# Production php.ini overrides
RUN { \
        echo 'expose_php=Off'; \
        echo 'memory_limit=256M'; \
        echo 'post_max_size=50M'; \
        echo 'upload_max_filesize=50M'; \
        echo 'date.timezone=Asia/Bangkok'; \
    } > /usr/local/etc/php/conf.d/zz-prod.ini

WORKDIR /var/www/backend

# Copy built code จาก builder stage
COPY --from=builder /var/www/backend /var/www/backend

# ตั้งสิทธิ์ writable folders ให้ www-data
RUN chown -R www-data:www-data /var/www/backend/writable \
    && chmod -R 775 /var/www/backend/writable

USER www-data

EXPOSE 9000
CMD ["php-fpm"]
